<credential-provider xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
        Declares that this provider supports passkeys (public key credentials).
        The system will show APS as an option when apps request passkeys.
    -->
    <capabilities>
        <capability name="android.credentials.TYPE_PUBLIC_KEY_CREDENTIAL" />
    </capabilities>
</credential-provider>
